ng-top: var(--list-spacing); padding-bottom: var(--list-spacing); position: relative; margin-inline-start: var(--list-indent);&quot; dir=&quot;auto&quot; data-line=&quot;2&quot;&gt;&lt;span style=&quot;box-sizing: border-box; color: transparent; position: relative; display: inline-flex; justify-content: center; align-items: center; float: inline-start; margin-inline-start: -0.8em;&quot; class=&quot;list-bullet&quot;&gt;&lt;/span&gt;因为&amp;nbsp;&lt;code style=&quot;box-sizing: border-box; color: var(--code-normal); font-family: var(--font-monospace); background-color: var(--code-background); border-radius: var(--code-radius); padding: 0.15em 0.3em; border: var(--code-border-width) solid var(--code-border-color); -webkit-box-decoration-break: clone;&quot;&gt;sys_len&lt;/code&gt;&amp;nbsp;(2860) &amp;gt;&amp;nbsp;&lt;code style=&quot;box-sizing: border-box; color: var(--code-normal); font-family: var(--font-monospace); background-color: var(--code-background); border-radius: var(--code-radius); padding: 0.15em 0.3em; border: var(--code-border-width) solid var(--code-border-color); -webkit-box-decoration-break: clone;&quot;&gt;ref_len&lt;/code&gt;&amp;nbsp;(997)，翻译结果比参考译文长&lt;/li&gt;&lt;li style=&quot;box-sizing: border-box; text-align: start; padding-top: var(--list-spacing); padding-bottom: var(--list-spacing); position: relative; margin-inline-start: var(--list-indent);&quot; dir=&quot;auto&quot; data-line=&quot;3&quot;&gt;&lt;span style=&quot;box-sizing: border-box; color: transparent; position: relative; display: inline-flex; justify-content: center; align-items: center; float: inline-start; margin-inline-start: -0.8em;&quot; class=&quot;list-bullet&quot;&gt;&lt;/span&gt;公式: BP = min(1, exp(1 - ref_len/sys_len))&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div style=&quot;box-sizing: border-box; color: rgb(34, 34, 34); font-family: Calibri, &amp;quot;Microsoft YaHei&amp;quot;, &amp;quot;??&amp;quot;, ui-sans-serif, -apple-system, &amp;quot;system-ui&a