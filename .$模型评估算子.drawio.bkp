rsor); user-select: none; margin-inline-start: -22px; padding: 0px 6px;&quot; class=&quot;heading-collapse-indicator collapse-indicator collapse-icon&quot;&gt;&lt;svg class=&quot;svg-icon right-triangle&quot; stroke-linejoin=&quot;round&quot; stroke-linecap=&quot;round&quot; stroke-width=&quot;2&quot; stroke=&quot;currentColor&quot; fill=&quot;none&quot; viewBox=&quot;0 0 24 24&quot; height=&quot;24&quot; width=&quot;24&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;/svg&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;/span&gt;&lt;/span&gt;4. ROUGE-Lsum (rougeLsum)&lt;/h2&gt;&lt;/div&gt;&lt;div style=&quot;box-sizing: border-box; color: rgb(34, 34, 34); font-family: Calibri, &amp;quot;Microsoft YaHei&amp;quot;, &amp;quot;??&amp;quot;, ui-sans-serif, -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe UI&amp;quot;, Roboto, Inter, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;, &amp;quot;Segoe UI Symbol&amp;quot;, sans-serif; caret-color: rgb(34, 34, 34); background-color: rgb(255, 255, 255);&quot; class=&quot;el-ul&quot;&gt;&lt;ul style=&quot;box-sizing: border-box; padding-inline-start: 0px; margin-block-start: var(--p-spacing); margin-block-end: var(--p-spacing); list-style-type: &amp;quot;​&amp;quot;;&quot; class=&quot;has-list-bullet&quot;&gt;&lt;li style=&quot;box-sizing: border-box; padding-top: var(--list-spacing); padding-bottom: var(--list-spacing); position: relative; margin-inline-start: 3ch;&quot; dir=&quot;auto&quot; data-line=&quot;0&quot;&gt;&lt;span style=&quot;box-sizing: border-box; color: transparent; position: relative; display: inline-flex; justify-content: center; align-items: center; float: inline-start; margin-inline-start: -0.8em;&quot; class=&quot;list-bullet&quot;&gt;&lt;/span&gt;&lt;span style=&quot;box-sizing: border-box; color: var(--bold-color);&quot;&gt;值&lt;/span&gt;: 0.3897 (38.97%)&lt;/li&gt;&lt;li style=&quot;box-sizing: border-box; padding-top: var(--list-spacing); padding-