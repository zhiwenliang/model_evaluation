  <diagram id="E4L1kjLXb85TXoBJHbN7" name="入参">
    <mxGraphModel dx="2175" dy="1283" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="38Org30Iop9ytJJ_aAH5-2" value="数据集相关参数" style="swimlane;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="720" height="340" as="geometry">
            <mxRectangle x="120" y="150" width="140" height="30" as="alternateBounds" />
          </mxGeometry>
        </mxCell>
        <mxCell id="xwTdUyV7RWqF_U8dc8yI-5" value="&lt;b&gt;通用参数&lt;/b&gt;&lt;div&gt;1. DATASET_TYPE: 数据集类型，支持用户自定义数据集和内置数据集&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;- BUILT_IN：内置数据集&lt;/span&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- CUSTOM：用户自定义数据集&lt;/div&gt;&lt;div&gt;2. EVALUATION_METRICS: 评估指标，多个指标使用 &quot;,&quot; 分隔开，不传时使用通用的默认指标进行评估&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- 通用指标：ROUGE-1, ROUGE-2, ROUGE-L, BLEU-4&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- 其他指标&lt;br&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;" vertex="1" parent="38Org30Iop9ytJJ_aAH5-2">
          <mxGeometry x="21" y="40" width="679" height="130" as="geometry" />
        </mxCell>
        <mxCell id="xwTdUyV7RWqF_U8dc8yI-6" value="&lt;b&gt;用户自定义数据集&lt;/b&gt;&lt;div&gt;1. CUSTOM_DATASET_PATH: 自定义数据集路径&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- 支持文件夹和jsonl文件，多个路径使用 &quot;,&quot; 分隔&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- 文件夹内需包含数据集对应的jsonl文件&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- jsonl文件内容请使用平台数据集标准格式&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;" vertex="1" parent="38Org30Iop9ytJJ_aAH5-2">
          <mxGeometry x="20" y="190" width="330" height="120" as="geometry" />
        </mxCell>
        <mxCell id="xwTdUyV7RWqF_U8dc8yI-10" value="&lt;b&gt;内置数据集&lt;/b&gt;&lt;div&gt;1. BUILT_IN_DATASET: 内置数据集名称，部分指标和数据集存在特定的 n-n 关系，请注意区分&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;" vertex="1" parent="38Org30Iop9ytJJ_aAH5-2">
          <mxGeometry x="370" y="190" width="330" height="120" as="geometry" />
        </mxCell>
        <mxCell id="NC93CiNfIvYoerjGRhLO-1" value="模型相关参数" style="swimlane;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="420" width="720" height="480" as="geometry" />
        </mxCell>
        <mxCell id="9GSZwmMmW7YQvDfb2fwR-1" value="单个模型配置" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;" vertex="1" parent="NC93CiNfIvYoerjGRhLO-1">
          <mxGeometry x="20" y="90" width="680" height="370" as="geometry" />
        </mxCell>
        <mxCell id="AZj0HJK31rcUOYE9N9vm-1" value="&lt;b&gt;通用参数&lt;/b&gt;&lt;div&gt;1. MODEL_CONFIG_NAME: 模型配置名称&lt;/div&gt;&lt;div&gt;2. MODEL_TYPE: 模型类型&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- BUILT_IN: 内置模型，根据内置配置决定模型加载和使用方式&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- API: 推理服务API，仅提供API，兼容 OPENAI 规范推理接口&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- CUSTOM: 自定义模型&lt;/div&gt;&lt;div&gt;3. PROMPT: 提示词&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;" vertex="1" parent="NC93CiNfIvYoerjGRhLO-1">
          <mxGeometry x="32.5" y="120" width="655" height="130" as="geometry" />
        </mxCell>
        <mxCell id="AZj0HJK31rcUOYE9N9vm-5" value="&lt;b&gt;内置模型&lt;/b&gt;&lt;div&gt;1. BUILD_IN_MODEL_NAME: 内置模型名称&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;" vertex="1" parent="NC93CiNfIvYoerjGRhLO-1">
          <mxGeometry x="255" y="280" width="210" height="70" as="geometry" />
        </mxCell>
        <mxCell id="AZj0HJK31rcUOYE9N9vm-7" value="&lt;b&gt;自定义模型&lt;/b&gt;&lt;div&gt;1. CUSTOM_MODEL_NAME: 自定义模型名称&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;2. BASE_MODEL_PATH: 基础模型路径&lt;/span&gt;&lt;/div&gt;&lt;div&gt;3. LORA_WEIGHT_PATH: LoRA权重路径，有的话就会加载，否则不加载&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;" vertex="1" parent="NC93CiNfIvYoerjGRhLO-1">
          <mxGeometry x="477.5" y="280" width="210" height="170" as="geometry" />
        </mxCell>
        <mxCell id="AZj0HJK31rcUOYE9N9vm-6" value="&lt;b&gt;推理服务API&lt;/b&gt;&lt;div&gt;1. API_URL: API地址&lt;br&gt;&lt;/div&gt;&lt;div&gt;2. API_KEY: API的key&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;" vertex="1" parent="NC93CiNfIvYoerjGRhLO-1">
          <mxGeometry x="32.5" y="280" width="210" height="70" as="geometry" />
        </mxCell>
        <mxCell id="9GSZwmMmW7YQvDfb2fwR-8" value="1. MODEL_CONFIGS: 支持传入多模型配置，使用 json 数组字符串形式，数组中 json 对象参考下方单个模型配置设置" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;" vertex="1" parent="NC93CiNfIvYoerjGRhLO-1">
          <mxGeometry x="25" y="50" width="650" height="30" as="geometry" />
        </mxCell>
        <mxCell id="AZj0HJK31rcUOYE9N9vm-3" value="其他参数" style="swimlane;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="940" width="720" height="160" as="geometry" />
        </mxCell>
        <mxCell id="AZj0HJK31rcUOYE9N9vm-4" value="&lt;b&gt;通用参数&lt;/b&gt;&lt;div&gt;1. OPERATION_TYPE： 操作类型，批量推理模式（BATCH_INFERENCE），评估模式（EVALUATION），裁判模式（JUDGE）&lt;br&gt;&lt;/div&gt;&lt;div&gt;2. INFERENCE_RESULT: 推理结果路径&lt;/div&gt;&lt;div&gt;3.&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;EVALUATION_RESULT:&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;评估结果路径&lt;/span&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;" vertex="1" parent="AZj0HJK31rcUOYE9N9vm-3">
          <mxGeometry x="20" y="40" width="680" height="90" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
